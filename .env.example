DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/keinage

# Garage / S3-compatible media storage (optional)
# If not set, media files are stored under the local uploads/ directory.
# S3_ENDPOINT=http://127.0.0.1:3900
# S3_REGION=us-east-1
# S3_BUCKET=keinage-media
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_FORCE_PATH_STYLE=true

# SMTP settings for PIN reset email (optional)
# If not configured, reset URL will be shown directly on screen instead.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-password-here
SMTP_FROM=noreply@example.com
