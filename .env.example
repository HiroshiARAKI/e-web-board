DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/keinage

# Trust reverse-proxy IP headers only when every request passes through
# infrastructure that overwrites them, such as ALB / CloudFront / Nginx.
TRUST_PROXY_HEADERS=false

# Optional S3-compatible media storage
# 既定ではローカル uploads/ に保存します。利用する場合のみ設定してください。
# 例: rustfs (alpha) を使う場合
# `pnpm dev` のようにホストで app を動かす場合:
# S3_ENDPOINT=http://127.0.0.1:9000
# Docker Compose で app を動かす場合:
# S3_INTERNAL_ENDPOINT=http://rustfs:9000
# S3_REGION=us-east-1
# S3_BUCKET=keinage-media
# S3_ACCESS_KEY_ID=rustfsadmin
# S3_SECRET_ACCESS_KEY=rustfsadmin
# S3_FORCE_PATH_STYLE=true

# Public origin used in emailed signup / PIN reset links and OAuth callbacks.
# Use the same origin that opens in the browser. Do not use a bind address
# such as http://0.0.0.0:3000 here; use http://localhost:3000 for local dev.
# Example: https://keinage.example.com
APP_PUBLIC_ORIGIN=http://localhost:3000

# Local-development escape hatch for unauthenticated owner-signup preview links.
# Only honored outside production, and only when APP_PUBLIC_ORIGIN points to localhost.
ALLOW_UNAUTHENTICATED_SIGNUP_PREVIEW=false

# Optional Google OAuth/OIDC for owner/shared signup and login.
# These Google-specific variable names are kept for backward compatibility.
# Configure the Google OAuth redirect URI as:
# ${APP_PUBLIC_ORIGIN}/api/auth/google/callback
GOOGLE_OAUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# SMTP settings for PIN reset email (optional)
# If not configured, unauthenticated email-based signup / PIN reset stays disabled.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-password-here
SMTP_FROM=noreply@example.com
