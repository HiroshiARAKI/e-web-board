DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/keinage

# Deployment mode. Leave unset for OSS/self-hosted. Official SaaS production
# should set `official-saas`, which enables strict startup security checks.
# KEINAGE_DEPLOYMENT_MODE=official-saas

# Trust reverse-proxy IP headers only when every request passes through
# infrastructure that overwrites them, such as ALB / CloudFront / Nginx.
TRUST_PROXY_HEADERS=false

# Optional S3 / S3-compatible media storage.
# Leave all S3_* connection values empty to store files in local uploads/.
# AWS S3 + IAM Role: set region and bucket. Leave endpoint and static
# credentials empty so the AWS SDK default credential provider chain is used
# (example: region ap-northeast-1, bucket keinage-storage-prod).
# RustFS / MinIO: also set endpoint, path-style, and static credentials
# (example: endpoint http://127.0.0.1:9000, internal endpoint http://rustfs:9000,
# region us-east-1, bucket keinage-media, credentials rustfsadmin/rustfsadmin).
# Local PC -> AWS S3: set S3_ACCESS_KEY_ID and S3_SECRET_ACCESS_KEY as a pair.
# S3_REGION=
# S3_BUCKET=
# S3_ENDPOINT=
# S3_INTERNAL_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=
# S3_PRESIGNED_UPLOAD_EXPIRES_SECONDS=900
# Optional public CDN/base URL for public-board media delivery.
# Direct public URL mode, mainly for S3-compatible local storage such as RustFS / MinIO.
# S3_PUBLIC_BASE_URL=https://media.example.com
# CLOUDFRONT_BASE_URL=https://cdn.example.com
#
# AWS S3 + private CloudFront signed URL delivery.
# Browser-facing media URLs become STORAGE_PUBLIC_BASE_URL/<mediaId>, then the app
# checks board access and redirects to a short-lived signed STORAGE_CDN_BASE_URL URL.
# STORAGE_DELIVERY_MODE=cloudfront-signed-url
# STORAGE_PUBLIC_BASE_URL=https://app.example.com/uploads
# STORAGE_CDN_BASE_URL=https://storage.example.com
# CLOUDFRONT_KEY_PAIR_ID=Kxxxxxxxxxxxx
# CLOUDFRONT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# CLOUDFRONT_SIGNED_URL_EXPIRES_SECONDS=300

# Public origin used in emailed signup / PIN reset links and OAuth callbacks.
# Use the same origin that opens in the browser. Do not use a bind address
# such as http://0.0.0.0:3000 here; use http://localhost:3000 for local dev.
# Example: https://keinage.example.com
APP_PUBLIC_ORIGIN=http://localhost:3000

# Local-development escape hatch for unauthenticated owner-signup preview links.
# Only honored outside production, and only when APP_PUBLIC_ORIGIN points to localhost.
ALLOW_UNAUTHENTICATED_SIGNUP_PREVIEW=false

# Optional Google OAuth/OIDC for owner/shared signup and login.
# These Google-specific variable names are kept for backward compatibility.
# Configure the Google OAuth redirect URI as:
# ${APP_PUBLIC_ORIGIN}/api/auth/google/callback
GOOGLE_OAUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Optional Super Owner bootstrap.
# Super Owner is granted only once, to an authenticated Owner whose verified
# email matches SUPER_OWNER_EMAIL. Official SaaS should require Google OIDC.
SUPER_OWNER_EMAIL=
SUPER_OWNER_BOOTSTRAP_ENABLED=false
SUPER_OWNER_REQUIRE_GOOGLE=false

# Optional billing / plan foundation.
# Self-hosted defaults: billing disabled and plan enforcement unlimited.
# Official SaaS can set BILLING_MODE=stripe and PLAN_ENFORCEMENT_MODE=billing.
BILLING_MODE=disabled
# disabled | stripe
PLAN_ENFORCEMENT_MODE=unlimited
# unlimited | local | billing
UPLOAD_MAX_BYTES=0
# 0 means unlimited for self-hosted/unlimited mode. Official SaaS uses plan limits first.

# Stripe Billing settings (only required when BILLING_MODE=stripe).
# Never commit real secret keys or price IDs.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_LITE_MONTHLY=
STRIPE_PRICE_LITE_YEARLY=
STRIPE_PRICE_STANDARD_MONTHLY=
STRIPE_PRICE_STANDARD_YEARLY=
STRIPE_PRICE_STANDARD_PLUS_MONTHLY=
STRIPE_PRICE_STANDARD_PLUS_YEARLY=

# SMTP settings for PIN reset email (optional)
# If not configured, unauthenticated email-based signup / PIN reset stays disabled.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-password-here
SMTP_FROM=noreply@example.com

# SMTP settings for contact form email (optional)
# If not configured, contact form stays disabled.
CONTACT_SMTP_HOST=smtp.example.com
CONTACT_SMTP_PORT=587
CONTACT_SMTP_USER=noreply@example.com
CONTACT_SMTP_PASS=your-password-here
CONTACT_SMTP_FROM=noreply@example.com
CONTACT_TO_EMAIL=contact@example.com
